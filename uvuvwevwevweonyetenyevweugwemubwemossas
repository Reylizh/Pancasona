local function UpdatePlayerList(searchText)
    for _, child in pairs(ListScroll:GetChildren()) do if child:IsA("TextButton") then child:Destroy() end end
    searchText = string.lower(searchText or "")
    local count = 0
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and (string.find(string.lower(p.Name), searchText) or string.find(string.lower(p.DisplayName), searchText)) then
            local pBtn = Instance.new("TextButton", ListScroll)
            pBtn.Size = UDim2.new(1, -10, 0, 30); pBtn.BackgroundColor3 = Color3.fromRGB(60, 0, 90); pBtn.Text = "👤 " .. p.DisplayName .. " (@" .. p.Name .. ")"; pBtn.TextColor3 = Color3.new(1,1,1); pBtn.Font = Enum.Font.Gotham; pBtn.TextSize = 12
            Instance.new("UICorner", pBtn).CornerRadius = UDim.new(0, 4)
            pBtn.MouseButton1Click:Connect(function() if p.Character and p.Character:FindFirstChild("HumanoidRootPart") and RootPart then RootPart.CFrame = p.Character.HumanoidRootPart.CFrame end end)
            count = count + 1
        end
    end
    ListScroll.CanvasSize = UDim2.new(0, 0, 0, count * 34)
end
