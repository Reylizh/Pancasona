local function CreateToggle(parent, title, callback)
    local ToggleFrame = Instance.new("Frame", parent); ToggleFrame.Size = UDim2.new(1, 0, 0, 40); ToggleFrame.BackgroundColor3 = Color3.fromRGB(40, 0, 60); Instance.new("UICorner", ToggleFrame).CornerRadius = UDim.new(0, 8)
