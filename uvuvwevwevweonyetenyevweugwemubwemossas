-- Movement (Fly, Noclip, Spinbot)
local bg, bv
local function ToggleFly(state)
    States.Fly = state
    if state then
        bg = Instance.new("BodyGyro", RootPart); bg.P = 9e5; bg.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
        bv = Instance.new("BodyVelocity", RootPart); bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
        Humanoid.PlatformStand = true
    else
        Humanoid.PlatformStand = false
        if bg then bg:Destroy() end
        if bv then bv:Destroy() end
    end
end

RunService.RenderStepped:Connect(function()
    if States.Fly and RootPart and bv and bg then
        local moveDir = Vector3.new()
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir += Camera.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir -= Camera.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir -= Camera.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir += Camera.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveDir += Vector3.new(0, 1, 0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then moveDir -= Vector3.new(0, 1, 0) end
        if moveDir.Magnitude > 0 then moveDir = moveDir.Unit end
        bv.Velocity = moveDir * States.FlySpeed
        bg.CFrame = Camera.CFrame
    end
end)

RunService.Stepped:Connect(function()
    if States.Noclip and Character then
        for _, p in pairs(Character:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide = false end end
    end
    if States.Spinbot and RootPart then RootPart.CFrame = RootPart.CFrame * CFrame.Angles(0, math.rad(50), 0) end
    if States.HitboxExpander then
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local hrp = p.Character.HumanoidRootPart
                hrp.Size = Vector3.new(States.HitboxSize, States.HitboxSize, States.HitboxSize)
                hrp.Transparency = 0.5
                hrp.BrickColor = BrickColor.new("Bright blue")
                hrp.CanCollide = false
            end
        end
    end
end)

UserInputService.JumpRequest:Connect(function() if States.InfJump and Humanoid then Humanoid:ChangeState(Enum.HumanoidStateType.Jumping) end end)
Mouse.Button1Down:Connect(function() if States.ClickTP and UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) and Mouse.Target and RootPart then RootPart.CFrame = CFrame.new(Mouse.Hit.p + Vector3.new(0, 3, 0)) end end)

-- ESP
local espHighlights = {}
local function CreateESP(player)
    if not player.Character then return end
    local hl = Instance.new("Highlight", player.Character); hl.Adornee = player.Character
    hl.FillColor = Color3.fromRGB(255, 0, 0); hl.OutlineColor = Color3.fromRGB(255, 255, 255)
    hl.FillTransparency = 0.5; hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    espHighlights[player] = hl
end
local function ToggleESP(state)
    States.ESP = state
    if state then
        for _, p in pairs(Players:GetPlayers()) do if p ~= LocalPlayer then CreateESP(p) end end
        Players.PlayerAdded:Connect(function(p) p.CharacterAdded:Connect(function() if States.ESP then CreateESP(p) end end) end)
    else
        for _, hl in pairs(espHighlights) do hl:Destroy() end; espHighlights = {}
    end
end

-- Mouse Trail (Drawing with Mouse)
local trailParts = {}
Mouse.Move:Connect(function()
    if States.MouseTrail and Mouse.Hit then
        local p = Instance.new("Part", workspace)
        p.Size = Vector3.new(0.5, 0.5, 0.5)
        p.Anchored = true; p.CanCollide = false
        p.CFrame = CFrame.new(Mouse.Hit.p)
